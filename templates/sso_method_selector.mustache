
<div class="auth-voidc-sso-selector">
    <div class="auth-voidc-sso-selector__header">
        <img class="auth-voidc-sso-selector__brand" src="/theme/vloom/pix/EdraPath-logo-navi.svg" alt="{{brandalt}}">
    </div>

    <a class="auth-voidc-sso-selector__back" href="{{backurl}}">
        <span aria-hidden="true">&#8249;</span>
        <span>{{backlabel}}</span>
    </a>

    <div class="auth-voidc-sso-selector__body">
        <h1 class="auth-voidc-sso-selector__title">{{title}}</h1>

        <form class="auth-voidc-sso-selector__search" method="get">
            <label class="accesshide" for="auth-voidc-sso-selector-query">{{searchplaceholder}}</label>
            <span class="auth-voidc-sso-selector__search-icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
                    <path d="M20 20L16.5 16.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
            </span>
            <input
                id="auth-voidc-sso-selector-query"
                type="text"
                name="q"
                value="{{searchquery}}"
                placeholder="{{searchplaceholder}}"
                autocomplete="off"
            >
            <button type="submit" class="auth-voidc-sso-selector__search-submit" aria-label="{{searchplaceholder}}">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 12H18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M13 7L18 12L13 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </form>

        <div class="auth-voidc-sso-selector__grid">
            {{#providers}}
                <a class="auth-voidc-sso-selector__card" href="{{url}}" title="{{name}}" aria-label="{{name}}">
                    {{{iconhtml}}}
                    <span class="auth-voidc-sso-selector__card-name">{{name}}</span>
                </a>
            {{/providers}}
            {{^providers}}
                <div class="auth-voidc-sso-selector__empty">{{emptylabel}}</div>
            {{/providers}}
        </div>
    </div>
</div>
